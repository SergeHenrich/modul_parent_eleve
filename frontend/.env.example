# Configuration de l'API
VITE_API_URL=http://localhost:5000/api

# Configuration de l'environnement
VITE_APP_NAME=EDUSMART-CM
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Portail Parent/Élève pour EDUSMART-CM

# Configuration de développement
VITE_DEV_MODE=true
VITE_DEBUG_MODE=false

# Configuration des fonctionnalités
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_OFFLINE_MODE=false
VITE_ENABLE_ANALYTICS=false

# Configuration de sécurité
VITE_ENABLE_HTTPS=false
VITE_SESSION_TIMEOUT=1440

# Configuration de l'interface
VITE_DEFAULT_LANGUAGE=fr
VITE_DEFAULT_THEME=light
VITE_ENABLE_DARK_MODE=false

# Configuration des uploads
VITE_MAX_FILE_SIZE=5242880
VITE_ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,jpeg,png

# URLs externes
VITE_SUPPORT_EMAIL=support@nexatec-solutions.cm
VITE_SUPPORT_PHONE=+237690123456
VITE_COMPANY_WEBSITE=https://nexatec-solutions.cm